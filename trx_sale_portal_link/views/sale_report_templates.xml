<odoo>

    <template id="report_saleorder_document_portal_link"
              name="Presupuesto: boton de aprobacion y firma en portal"
              inherit_id="sale.report_saleorder_document">

        <!-- Boton de aprobacion y firma al final del presupuesto -->
        <xpath expr="//p[@id='fiscal_position_remark']" position="after">
            <div t-if="doc.state in ('draft', 'sent')"
                 name="trx_portal_sign_link"
                 class="mt-4 mb-3 text-center">
                <a t-att-href="doc.get_base_url() + doc.get_portal_url()"
                   style="display: inline-block; background-color: #4da6ff; color: #ffffff; font-size: 17px; font-weight: bold; padding: 14px 36px; border-radius: 8px; text-decoration: none;">
                    APROBAR Y FIRMAR ESTE PRESUPUESTO
                </a>
            </div>
        </xpath>

        <!-- El PDF estandar solo imprime la nota del termino de pago; si la nota
             esta vacia, mostramos el nombre del termino para que igual figure
             (una unica vez) en el presupuesto. -->
        <xpath expr="//p[@t-if='not is_html_empty(doc.payment_term_id.note)']" position="after">
            <p t-if="doc.payment_term_id and is_html_empty(doc.payment_term_id.note)"
               name="trx_payment_term_name">
                <span t-field="doc.payment_term_id.name"/>
            </p>
        </xpath>

    </template>

</odoo>
